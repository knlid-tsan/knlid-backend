# Драйвер хранилища файлов: local (диск) | s3 (S3-совместимое облако)
STORAGE_DRIVER=local

# ─── S3 (заполнить при STORAGE_DRIVER=s3) ───────────────────────────────────
# Endpoint S3-совместимого хранилища (Yandex Object Storage, Selectel, Minio и т.д.)
S3_ENDPOINT=https://storage.yandexcloud.net

# Регион (для Yandex: ru-central1)
S3_REGION=ru-central1

# Имя бакета
S3_BUCKET=knlid-prod

# Ключи доступа
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key

# Публичный base URL для аватаров (CDN или публичный бакет)
# Пример: https://knlid-prod.storage.yandexcloud.net
S3_PUBLIC_BASE_URL=https://your-bucket.storage.yandexcloud.net
